[bar/top]
font-0 = NotoSans-Regular:size=11
font-1 = NotoSans-Regular:size=11

background = #161919
foreground = #D3D7CF

;modules-left =
modules-center = i3
modules-right = date 

tray-position = right
; If true, the bar will not shift its
; contents when the tray changes
tray-detached = false
; Tray icon max size
tray-maxsize = 16
; Pad the sides of each tray icon
tray-padding = 7
; Scale factor for tray clients
tray-scale = 1

[module/i3]
type = internal/i3
label-focused-foreground = #ffffff
label-focused-background = #282e2f
label-focused-padding = 6
; This does not seem to work
label-focused-underline = #09c1f9

label-unfocused-foreground = #ffffff
label-unfocused-background = #1e2324
label-unfocused-padding = 6

[module/date]
type = internal/date
date = %Y-%m-%d%
time = %H:%M:%S

; Available tags:
;   <label> (default)
format = <label>
format-background = #161919
format-foreground = #fff

; Available tokens:
;   %date%
;   %time%
; Default: %date%
label = %date% %time%
label-font = 1
label-foreground = #ffffff
