[include]
  path= ~/.gitconfig.user

[alias]
  history = log --graph --pretty=format:'%C(bold blue)%ar%Creset %C(bold magenta)[%an]%C(reset)%C(yellow)%d%Creset %s'

[color "diff"]
  new = green
  old = red
  frag = blue bold
  meta = magenta bold

[color "status"]
  added = green
  changed = yellow
  untracked = red
[credential]
	helper = store
